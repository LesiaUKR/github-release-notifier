# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_notifier

# Redis
REDIS_URL=redis://localhost:6379

# GitHub API (optional — without token: 60 req/hr, with: 5000 req/hr)
GITHUB_TOKEN=

# SMTP (email sending)
# Dev: leave empty — Ethereal test account will be created automatically
# Prod: use real SMTP credentials (e.g. Brevo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@github-release-notifier.com

# App
BASE_URL=http://localhost:3000

# Scanner
SCAN_INTERVAL_MS=300000

# gRPC
GRPC_PORT=50051
