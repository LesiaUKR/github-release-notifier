# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_notifier

# Redis
REDIS_URL=redis://localhost:6379

# GitHub API (optional — without token: 60 req/hr, with: 5000 req/hr)
GITHUB_TOKEN=

# Email sending
# Option 1: Resend HTTP API (recommended for production — works on hosts that block SMTP)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Option 2: SMTP (Nodemailer) — for local dev or hosts that allow outbound SMTP
# Dev: leave all empty — Ethereal test account will be created automatically
# Prod: set host/user/pass for your SMTP provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@github-release-notifier.com

# App
BASE_URL=http://localhost:3000

# Scanner
SCAN_INTERVAL_MS=300000

# gRPC
GRPC_PORT=50051
